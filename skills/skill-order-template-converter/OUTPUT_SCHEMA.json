{
  "skill_id": "skill-order-template-converter",
  "version": "1.1.0",
  "output_type": "order_confirmation",
  "description": "订单确认单输出结构，包含订单头、商品明细、汇总信息三部分，支持31字段华鼎模板和pending字段处理",
  "fields": [
    {
      "section_id": "order_header",
      "title": "订单头信息",
      "confidence_threshold": 0.8,
      "fields": [
        { "field_id": "order_no", "label": "订单编号", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "MANUAL_MODIFIED", "PENDING"] },
        { "field_id": "customer_name", "label": "客户名称", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "MANUAL_MODIFIED", "NEED_INPUT", "PENDING"] },
        { "field_id": "contact_person", "label": "联系人", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "MANUAL_MODIFIED", "PENDING"] },
        { "field_id": "delivery_address", "label": "收货地址", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "MANUAL_MODIFIED", "NEED_INPUT", "PENDING"] },
        { "field_id": "contact_phone", "label": "联系电话", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "MANUAL_MODIFIED", "PENDING"] },
        { "field_id": "delivery_date", "label": "发货日期", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "MANUAL_MODIFIED", "NEED_INPUT", "PENDING"] },
        { "field_id": "third_party_order_no", "label": "三方单号", "status_types": ["CONFIRMED", "PENDING"], "description": "格式：CUS_{cid}_{order}_{ts}" },
        { "field_id": "huading_store_code", "label": "华鼎门店编码", "status_types": ["CONFIRMED", "PENDING"], "description": "通过get_huading_store_code工具获取" },
        { "field_id": "warehouse_code", "label": "仓库编码", "status_types": ["CONFIRMED", "PENDING"], "description": "通过get_warehouse_code工具获取" }
      ]
    },
    {
      "section_id": "order_items",
      "title": "商品明细",
      "confidence_threshold": 0.8,
      "row_based": true,
      "columns": [
        { "col_id": "sku_code", "label": "商品编码", "width": "120px", "sortable": true },
        { "col_id": "sku_name", "label": "商品名称", "width": "180px" },
        { "col_id": "spec", "label": "规格", "width": "140px" },
        { "col_id": "quantity", "label": "数量", "width": "80px", "align": "right" },
        { "col_id": "unit", "label": "单位", "width": "80px" },
        { "col_id": "matched_sku", "label": "系统SKU", "width": "140px" },
        { "col_id": "matched_sku_name", "label": "系统商品名", "width": "180px" },
        { "col_id": "unit_conversion", "label": "换算", "width": "100px" },
        { "col_id": "unit_type", "label": "单位类型", "width": "100px", "description": "通过get_unit_type工具获取" }
      ],
      "row_actions": [
        { "action_id": "confirm_item", "label": "确认", "icon": "check", "type": "primary" },
        { "action_id": "edit_item", "label": "修改", "icon": "edit", "type": "default" },
        { "action_id": "delete_item", "label": "删除", "icon": "delete", "type": "danger" }
      ]
    },
    {
      "section_id": "summary",
      "title": "汇总信息",
      "confidence_threshold": 0.8,
      "fields": [
        { "field_id": "total_items", "label": "商品种数" },
        { "field_id": "total_quantity", "label": "商品总件数" },
        { "field_id": "overall_confidence", "label": "整体置信度" },
        { "field_id": "fields_filled", "label": "已填充字段数", "description": "31字段模板中已填充的字段数量" },
        { "field_id": "fields_pending", "label": "待确认字段数", "description": "标记为pending状态的字段数量" }
      ]
    },
    {
      "section_id": "pending_details",
      "title": "待确认字段详情",
      "collapsible": true,
      "default_collapsed": true,
      "fields": [
        { "field_id": "pending_field_details", "label": "Pending字段列表", "type": "array", "description": "包含所有pending字段的详细信息" }
      ]
    }
  ],
  "system_actions": [
    {
      "action_id": "generate_huading_template",
      "label": "生成华鼎标准模板",
      "type": "primary",
      "icon": "download",
      "enabled_when": "所有CONFIRMED字段 ≥ 95% 或 包含PENDING字段且用户确认"
    },
    {
      "action_id": "download_template",
      "label": "下载31字段模板",
      "type": "primary",
      "icon": "file-excel",
      "enabled_when": "模板生成完成"
    },
    {
      "action_id": "skip_pending_confirm",
      "label": "跳过Pending确认",
      "type": "secondary",
      "icon": "warning",
      "enabled_when": "存在PENDING字段",
      "description": "跳过pending字段确认，使用当前值生成模板"
    },
    {
      "action_id": "export_excel",
      "label": "导出Excel",
      "type": "secondary",
      "icon": "file-excel"
    },
    {
      "action_id": "reject_all",
      "label": "全部重填",
      "type": "danger",
      "icon": "refresh"
    }
  ],
  "metadata": {
    "task_id": "string",
    "process_time_ms": "number",
    "model_used": "string",
    "template_version": "string",
    "huading_template_31_fields": "object"
  }
}
