{
  "output_type": "order_confirmation",
  "layout": "two_column",
  "sections": [
    {
      "section_id": "order_header",
      "layout": "vertical_form",
      "collapsible": false,
      "fields": [
        { "field_id": "order_no", "render_as": "readonly_text", "show_confidence": false },
        { "field_id": "customer_name", "render_as": "editable_text", "highlight_on_status": ["LOW_CONFIDENCE", "MANUAL_MODIFIED", "PENDING"], "show_confidence": true },
        { "field_id": "contact_person", "render_as": "editable_text", "highlight_on_status": ["LOW_CONFIDENCE", "PENDING"], "show_confidence": true },
        { "field_id": "delivery_address", "render_as": "editable_text", "highlight_on_status": ["LOW_CONFIDENCE", "PENDING"], "show_confidence": true },
        { "field_id": "contact_phone", "render_as": "readonly_text", "show_confidence": true },
        { "field_id": "delivery_date", "render_as": "editable_text", "show_confidence": true },
        { "field_id": "third_party_order_no", "render_as": "readonly_text", "show_confidence": false },
        { "field_id": "huading_store_code", "render_as": "editable_text", "highlight_on_status": ["PENDING"], "show_confidence": true },
        { "field_id": "warehouse_code", "render_as": "editable_text", "highlight_on_status": ["PENDING"], "show_confidence": true }
      ],
      "confidence_visual": {
        "high": { "color": "#52c41a", "icon": "check-circle" },
        "medium": { "color": "#faad14", "icon": "exclamation-circle" },
        "low": { "color": "#f5222d", "icon": "close-circle" },
        "pending": { "color": "#ffeb3b", "icon": "warning", "background": "#fffbe6", "border": "#ffe58f" }
      },
      "pending_highlight": {
        "enabled": true,
        "background_color": "#fffbe6",
        "border_color": "#ffe58f",
        "text_color": "#d48806",
        "icon": "warning",
        "show_annotation": true,
        "annotation_text": "待确认：{{pending_reason}}"
      }
    },
    {
      "section_id": "order_items",
      "layout": "table",
      "collapsible": false,
      "columns": [
        { "col_id": "sku_code", "label": "商品编码", "width": "120px", "sortable": true },
        { "col_id": "sku_name", "label": "商品名称", "width": "180px" },
        { "col_id": "spec", "label": "规格", "width": "140px" },
        { "col_id": "quantity", "label": "数量", "width": "80px", "align": "right" },
        { "col_id": "unit", "label": "单位", "width": "80px" },
        { "col_id": "matched_sku", "label": "系统SKU", "width": "140px" },
        { "col_id": "matched_sku_name", "label": "系统商品名", "width": "180px" },
        { "col_id": "unit_conversion", "label": "换算", "width": "100px" },
        { "col_id": "unit_type", "label": "单位类型", "width": "100px", "highlight_on_status": ["PENDING"] }
      ],
      "row_actions": [
        { "action_id": "confirm_item", "label": "确认", "icon": "check", "type": "primary" },
        { "action_id": "edit_item", "label": "修改", "icon": "edit", "type": "default" },
        { "action_id": "delete_item", "label": "删除", "icon": "delete", "type": "danger" }
      ],
      "striped": true,
      "hoverable": true,
      "empty_state": "暂无商品明细",
      "pending_row_highlight": {
        "enabled": true,
        "background_color": "#fffbe6",
        "condition": "row_has_pending_fields"
      }
    },
    {
      "section_id": "summary",
      "layout": "card",
      "collapsible": true,
      "defaultCollapsed": false,
      "fields": [
        { "field_id": "total_items", "render_as": "readonly_text" },
        { "field_id": "total_quantity", "render_as": "readonly_text" },
        { "field_id": "overall_confidence", "render_as": "confidence_badge" },
        { "field_id": "fields_filled", "render_as": "readonly_text", "suffix": "/31" },
        { "field_id": "fields_pending", "render_as": "pending_badge", "show_warning": true }
      ]
    },
    {
      "section_id": "pending_details",
      "layout": "table",
      "collapsible": true,
      "default_collapsed": true,
      "title": "待确认字段详情（{{pending_count}}个）",
      "columns": [
        { "col_id": "field_name", "label": "字段名称", "width": "150px" },
        { "col_id": "field_value", "label": "当前值", "width": "200px" },
        { "col_id": "pending_reason", "label": "待确认原因", "width": "250px" },
        { "col_id": "suggested_value", "label": "建议值", "width": "200px" },
        { "col_id": "actions", "label": "操作", "width": "120px" }
      ],
      "row_actions": [
        { "action_id": "confirm_pending_field", "label": "确认", "icon": "check", "type": "primary" },
        { "action_id": "edit_pending_field", "label": "修改", "icon": "edit", "type": "default" }
      ]
    }
  ],
  "system_actions_bar": {
    "position": "bottom_fixed",
    "background": "#ffffff",
    "shadow": "0 -2px 8px rgba(0,0,0,0.1)",
    "padding": "16px 24px",
    "actions": [
      { "action_id": "generate_huading_template", "render_as": "primary_button", "label": "生成华鼎标准模板", "icon": "download" },
      { "action_id": "download_template", "render_as": "primary_button", "label": "下载31字段模板", "icon": "file-excel", "visible_when": "template_generated" },
      { "action_id": "skip_pending_confirm", "render_as": "secondary_button", "label": "跳过Pending确认", "icon": "warning", "visible_when": "has_pending_fields", "danger": false },
      { "action_id": "export_excel", "render_as": "secondary_button", "label": "导出Excel", "icon": "file-excel" },
      { "action_id": "reject_all", "render_as": "text_button", "label": "全部重填", "danger": true, "icon": "refresh" }
    ]
  },
  "excel_template_31_fields": {
    "sheet_name": "华鼎出库单",
    "header_row": 1,
    "pending_cell_style": {
      "fill_color": "FFFF00",
      "fill_pattern": "solid",
      "font_color": "000000",
      "border_style": "thin"
    },
    "annotation_style": {
      "author": "AI助手",
      "text": "待确认：{{pending_reason}}"
    }
  }
}
