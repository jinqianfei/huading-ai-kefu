{
  "handlers": [
    {
      "action_id": "generate_huading_template",
      "trigger": "button_click",
      "request": {
        "action": "GENERATE_TEMPLATE",
        "payload": {
          "task_id": "{{task_id}}",
          "confirmed_fields": "{{all_confirmed_fields}}",
          "pending_fields": "{{all_pending_fields}}",
          "include_pending": "{{include_pending_fields}}",
          "output_format": "xlsx",
          "template_type": "huading_31_fields"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "download_file",
          "file_field": "template_file",
          "message": "华鼎标准模板已生成（31字段）",
          "message_type": "success",
          "pending_warning": "{{pending_fields_count}}个字段为待确认状态，已标记黄色高亮"
        },
        "error": {
          "render_type": "error_message",
          "message": "生成模板失败，请重试",
          "retry": true
        }
      },
      "loading": {
        "show": true,
        "text": "正在生成华鼎标准模板（31字段）..."
      }
    },
    {
      "action_id": "download_template",
      "trigger": "button_click",
      "request": {
        "action": "DOWNLOAD_TEMPLATE",
        "payload": {
          "task_id": "{{task_id}}",
          "template_id": "{{generated_template_id}}",
          "format": "xlsx"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "download_file",
          "file_field": "template_file",
          "message": "31字段模板下载成功",
          "message_type": "success"
        },
        "error": {
          "render_type": "error_message",
          "message": "下载模板失败，请重试",
          "retry": true
        }
      },
      "loading": {
        "show": true,
        "text": "正在下载模板..."
      }
    },
    {
      "action_id": "skip_pending_confirm",
      "trigger": "button_click",
      "request": {
        "action": "SKIP_PENDING_CONFIRM",
        "payload": {
          "task_id": "{{task_id}}",
          "pending_fields": "{{all_pending_fields}}",
          "skip_reason": "{{user_skip_reason}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "update_status",
          "update_fields": { "pending_fields_status": "SKIPPED", "allow_generate": true },
          "message": "已跳过Pending字段确认，可以继续生成模板",
          "message_type": "warning"
        },
        "error": {
          "render_type": "error_message",
          "message": "操作失败，请重试"
        }
      },
      "confirm": {
        "required": true,
        "title": "跳过Pending字段确认",
        "message": "存在{{pending_count}}个待确认字段，跳过确认后这些字段将使用当前值生成模板。是否继续？",
        "okText": "确认跳过",
        "cancelText": "取消",
        "input_required": true,
        "input_placeholder": "请输入跳过原因（必填）"
      },
      "loading": {
        "show": true,
        "text": "处理中..."
      }
    },
    {
      "action_id": "confirm_item",
      "trigger": "row_button_click",
      "request": {
        "action": "CONFIRM_ITEM",
        "payload": {
          "task_id": "{{task_id}}",
          "item_index": "{{row_index}}",
          "confirmed": true
        }
      },
      "response_handling": {
        "success": {
          "render_type": "update_row",
          "update_fields": { "status": "CONFIRMED", "confidence": 1.0 }
        }
      },
      "loading": {
        "show": true,
        "text": "正在保存..."
      }
    },
    {
      "action_id": "edit_item",
      "trigger": "row_button_click",
      "request": {
        "action": "EDIT_ITEM",
        "payload": {
          "task_id": "{{task_id}}",
          "item_index": "{{row_index}}",
          "edit_data": "{{user_input}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "update_row",
          "update_fields": { "status": "MANUAL_MODIFIED" }
        }
      },
      "confirm": {
        "required": true,
        "title": "确认修改",
        "message": "确定要修改这条记录吗？",
        "okText": "确认",
        "cancelText": "取消"
      },
      "loading": {
        "show": true,
        "text": "正在保存..."
      }
    },
    {
      "action_id": "delete_item",
      "trigger": "row_button_click",
      "request": {
        "action": "DELETE_ITEM",
        "payload": {
          "task_id": "{{task_id}}",
          "item_index": "{{row_index}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "delete_row"
        }
      },
      "confirm": {
        "required": true,
        "title": "确认删除",
        "message": "确定要删除这条记录吗？此操作不可撤销。",
        "okText": "删除",
        "cancelText": "取消"
      }
    },
    {
      "action_id": "reject_all",
      "trigger": "button_click",
      "request": {
        "action": "REJECT_ALL",
        "payload": {
          "task_id": "{{task_id}}",
          "reason": "{{user_reason}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "reset_form",
          "message": "已重置，请重新上传订单"
        }
      },
      "confirm": {
        "required": true,
        "title": "确认重填",
        "message": "确定要清空所有数据重新填写吗？之前的操作将被丢弃。",
        "okText": "确认重填",
        "cancelText": "取消"
      }
    },
    {
      "action_id": "confirm_pending_field",
      "trigger": "row_button_click",
      "request": {
        "action": "CONFIRM_PENDING_FIELD",
        "payload": {
          "task_id": "{{task_id}}",
          "field_id": "{{field_id}}",
          "confirmed_value": "{{field_value}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "update_row",
          "update_fields": { "status": "CONFIRMED", "pending": false },
          "message": "字段已确认",
          "message_type": "success"
        }
      },
      "loading": {
        "show": true,
        "text": "正在保存..."
      }
    },
    {
      "action_id": "edit_pending_field",
      "trigger": "row_button_click",
      "request": {
        "action": "EDIT_PENDING_FIELD",
        "payload": {
          "task_id": "{{task_id}}",
          "field_id": "{{field_id}}",
          "new_value": "{{user_input}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "update_row",
          "update_fields": { "status": "MANUAL_MODIFIED", "pending": false },
          "message": "字段已修改并确认",
          "message_type": "success"
        }
      },
      "loading": {
        "show": true,
        "text": "正在保存..."
      }
    },
    {
      "action_id": "export_excel",
      "trigger": "button_click",
      "request": {
        "action": "EXPORT_EXCEL",
        "payload": {
          "task_id": "{{task_id}}",
          "confirmed_fields": "{{all_confirmed_fields}}",
          "pending_fields": "{{all_pending_fields}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "download_file",
          "file_field": "excel_file"
        }
      },
      "loading": {
        "show": true,
        "text": "正在导出Excel..."
      }
    }
  ]
}
