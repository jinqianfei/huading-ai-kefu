{
  "version": "1.1.0",
  "handlers": [
    {
      "action_id": "confirm_and_continue",
      "trigger": "button_click",
      "request": {
        "action": "RECOGNITION_CONFIRMED",
        "payload": {
          "task_id": "{{task_id}}",
          "confirmed_fields": "{{all_confirmed_fields}}",
          "template_type": "{{template_type}}",
          "customer_id": "{{customer_id}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "show_message",
          "message": "识别结果已确认，正在处理...",
          "message_type": "success"
        }
      },
      "loading": {
        "show": true,
        "text": "正在加载模板转换..."
      }
    },
    {
      "action_id": "cancel",
      "trigger": "button_click",
      "request": {
        "action": "RECOGNITION_CANCEL",
        "payload": {
          "task_id": "{{task_id}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "reset_form",
          "message": "已取消，请重新上传"
        }
      }
    },
    {
      "action_id": "CONFIRM_PENDING_TASK",
      "trigger": "button_click",
      "description": "确认待处理的字段映射任务",
      "request": {
        "action": "CONFIRM_PENDING_MAPPING",
        "payload": {
          "task_id": "{{task_id}}",
          "pending_task_id": "{{pending_task_id}}",
          "field_type": "{{field_type}}",
          "original_value": "{{original_value}}",
          "selected_candidate_id": "{{selected_candidate_id}}",
          "manual_input_value": "{{manual_input_value}}",
          "confirm_action": "accept|reject|manual"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "update_pending_status",
          "refresh_section": "pending_mappings",
          "message": "映射已确认",
          "message_type": "success"
        },
        "error": {
          "render_type": "show_error",
          "message": "确认失败，请重试",
          "message_type": "error"
        }
      },
      "loading": {
        "show": true,
        "text": "正在确认映射..."
      }
    },
    {
      "action_id": "confirm_mapping",
      "trigger": "button_click",
      "description": "从候选列表中选择并确认映射",
      "parent_action": "CONFIRM_PENDING_TASK",
      "request": {
        "action": "CONFIRM_PENDING_MAPPING",
        "payload": {
          "pending_task_id": "{{pending_task_id}}",
          "selected_candidate_id": "{{selected_candidate_id}}",
          "confirm_action": "accept"
        }
      }
    },
    {
      "action_id": "reject_mapping",
      "trigger": "button_click",
      "description": "拒绝所有候选映射",
      "parent_action": "CONFIRM_PENDING_TASK",
      "request": {
        "action": "CONFIRM_PENDING_MAPPING",
        "payload": {
          "pending_task_id": "{{pending_task_id}}",
          "confirm_action": "reject"
        }
      }
    },
    {
      "action_id": "manual_input",
      "trigger": "button_click",
      "description": "手动输入映射值",
      "parent_action": "CONFIRM_PENDING_TASK",
      "request": {
        "action": "CONFIRM_PENDING_MAPPING",
        "payload": {
          "pending_task_id": "{{pending_task_id}}",
          "manual_input_value": "{{manual_input_value}}",
          "confirm_action": "manual"
        }
      }
    },
    {
      "action_id": "create_mapping_task",
      "trigger": "button_click",
      "description": "为未映射字段创建待确认任务",
      "request": {
        "action": "CREATE_PENDING_TASK",
        "payload": {
          "task_id": "{{task_id}}",
          "unmapped_field_id": "{{unmapped_field_id}}",
          "field_type": "{{field_type}}",
          "original_value": "{{original_value}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "move_to_pending",
          "refresh_sections": ["unmapped_fields", "pending_mappings"],
          "message": "已添加到待确认列表",
          "message_type": "success"
        }
      }
    },
    {
      "action_id": "ignore_field",
      "trigger": "button_click",
      "description": "忽略未映射字段",
      "request": {
        "action": "IGNORE_UNMAPPED_FIELD",
        "payload": {
          "unmapped_field_id": "{{unmapped_field_id}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "remove_from_list",
          "refresh_section": "unmapped_fields"
        }
      }
    }
  ]
}
