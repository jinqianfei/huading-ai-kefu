{
  "skill_id": "skill-sku-matcher",
  "version": "1.0.0",
  "output_type": "sku_match_result",
  "description": "SKU匹配结果，包含匹配类型、置信度、系统SKU信息",
  "fields": [
    {
      "section_id": "match_result",
      "title": "匹配结果",
      "confidence_threshold": 0.85,
      "fields": [
        {
          "field_id": "match_type",
          "label": "匹配类型",
          "status_types": ["CONFIRMED"],
          "match_type_enum": ["EXACT", "HISTORY", "SEMANTIC", "NOT_FOUND"]
        },
        {
          "field_id": "system_sku_code",
          "label": "系统SKU编码",
          "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"]
        },
        {
          "field_id": "system_sku_name",
          "label": "系统商品名",
          "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"]
        },
        {
          "field_id": "unit_conversion",
          "label": "单位换算",
          "status_types": ["CONFIRMED", "LOW_CONFIDENCE"]
        },
        {
          "field_id": "fee_coefficient",
          "label": "计费系数",
          "status_types": ["CONFIRMED"]
        },
        {
          "field_id": "confidence",
          "label": "置信度",
          "render_as": "confidence_badge"
        }
      ]
    },
    {
      "section_id": "alternatives",
      "title": "备选方案",
      "confidence_threshold": 0.6,
      "row_based": true,
      "columns": [
        { "col_id": "system_sku_code", "label": "系统SKU编码", "width": "140px" },
        { "col_id": "system_sku_name", "label": "系统商品名", "width": "200px" },
        { "col_id": "similarity", "label": "相似度", "width": "100px", "align": "right" },
        { "col_id": "action", "label": "操作", "width": "80px" }
      ],
      "row_actions": [
        { "action_id": "select_alternative", "label": "选择", "icon": "check", "type": "primary" }
      ]
    }
  ],
  "system_actions": [
    {
      "action_id": "confirm_match",
      "label": "确认匹配",
      "type": "primary",
      "icon": "check",
      "enabled_when": "confidence ≥ 0.85"
    },
    {
      "action_id": "manual_select",
      "label": "手动选择",
      "type": "secondary",
      "icon": "edit"
    }
  ],
  "metadata": {
    "task_id": "string",
    "match_count": "number",
    "process_time_ms": "number"
  }
}
