{
  "handlers": [
    {
      "action_id": "save_to_library",
      "trigger": "button_click",
      "description": "保存规则到规则库（仅高置信度字段）",
      "request": {
        "action": "SAVE_CONTRACT_RULES",
        "payload": {
          "task_id": "{{task_id}}",
          "customer_id": "{{customer_id}}",
          "rules": "{{all_confirmed_fields}}",
          "save_mode": "normal",
          "version": "2.0.0"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "show_message",
          "message": "规则已保存到规则库，下次账单计算将自动应用",
          "message_type": "success"
        },
        "error": {
          "render_type": "show_message",
          "message": "保存失败：{{error_message}}",
          "message_type": "error"
        }
      },
      "loading": {
        "show": true,
        "text": "正在保存规则..."
      },
      "confirm": {
        "required": true,
        "title": "确认保存",
        "message": "确定要将以上规则保存到规则库吗？",
        "okText": "确认保存",
        "cancelText": "取消"
      }
    },
    {
      "action_id": "save_with_override",
      "trigger": "button_click",
      "description": "强制保存（含低置信度字段）",
      "request": {
        "action": "SAVE_CONTRACT_RULES",
        "payload": {
          "task_id": "{{task_id}}",
          "customer_id": "{{customer_id}}",
          "rules": "{{all_fields}}",
          "save_mode": "override",
          "reason": "{{user_reason}}",
          "version": "2.0.0"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "show_message",
          "message": "规则已强制保存，请注意低置信度字段可能影响计算准确性",
          "message_type": "warning"
        },
        "error": {
          "render_type": "show_message",
          "message": "保存失败：{{error_message}}",
          "message_type": "error"
        }
      },
      "loading": {
        "show": true,
        "text": "正在保存规则..."
      },
      "confirm": {
        "required": true,
        "title": "强制保存确认",
        "message": "当前存在严重问题或低置信度字段，确定要强制保存吗？这可能影响账单计算准确性。",
        "okText": "确认强制保存",
        "cancelText": "取消"
      }
    },
    {
      "action_id": "reject_all",
      "trigger": "button_click",
      "description": "放弃当前解析结果，重新上传",
      "request": {
        "action": "REPARSE_CONTRACT",
        "payload": {
          "task_id": "{{task_id}}",
          "reason": "{{user_reason}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "reset_form",
          "message": "已重置，请重新上传合同"
        },
        "error": {
          "render_type": "show_message",
          "message": "重置失败：{{error_message}}",
          "message_type": "error"
        }
      },
      "confirm": {
        "required": true,
        "title": "确认重填",
        "message": "确定要放弃当前解析结果吗？"
      }
    },
    {
      "action_id": "mark_transfer_delivery_confusion",
      "trigger": "field_editing",
      "description": "标记调拨/共配混淆问题",
      "request": {
        "action": "MARK_CONFUSION",
        "payload": {
          "task_id": "{{task_id}}",
          "field_id": "transfer_delivery_distinction",
          "confusion_type": "not_distinguished",
          "note": "{{user_note}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "update_field",
          "field_id": "validation.transfer_delivery_distinction",
          "status": "NOT_FOUND",
          "confidence": 0.5
        }
      }
    },
    {
      "action_id": "add_product_coefficient",
      "trigger": "table_row_add",
      "description": "添加产品固定系数",
      "request": {
        "action": "ADD_PRODUCT_COEFFICIENT",
        "payload": {
          "task_id": "{{task_id}}",
          "product": "{{new_product_row}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "append_table_row",
          "section": "product_coefficients"
        }
      }
    },
    {
      "action_id": "delete_product_coefficient",
      "trigger": "table_row_delete",
      "description": "删除产品固定系数",
      "request": {
        "action": "DELETE_PRODUCT_COEFFICIENT",
        "payload": {
          "task_id": "{{task_id}}",
          "product_id": "{{product_id}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "remove_table_row",
          "section": "product_coefficients"
        }
      }
    },
    {
      "action_id": "add_transfer_route",
      "trigger": "matrix_cell_edit",
      "description": "添加调拨路线",
      "request": {
        "action": "ADD_TRANSFER_ROUTE",
        "payload": {
          "task_id": "{{task_id}}",
          "origin": "{{origin_warehouse}}",
          "destination": "{{destination_warehouse}}",
          "price": "{{price}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "update_matrix_cell"
        }
      }
    },
    {
      "action_id": "add_delivery_route",
      "trigger": "matrix_cell_edit",
      "description": "添加共配路线",
      "request": {
        "action": "ADD_DELIVERY_ROUTE",
        "payload": {
          "task_id": "{{task_id}}",
          "origin": "{{origin_warehouse}}",
          "destination": "{{destination}}",
          "price": "{{price}}",
          "min_fee": "{{min_fee}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "update_matrix_cell"
        }
      }
    },
    {
      "action_id": "export_rules",
      "trigger": "button_click",
      "description": "导出规则为JSON文件",
      "request": {
        "action": "EXPORT_RULES",
        "payload": {
          "task_id": "{{task_id}}",
          "format": "json"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "download_file",
          "filename": "contract_rules_{{customer_id}}_{{timestamp}}.json"
        }
      }
    },
    {
      "action_id": "validate_rules",
      "trigger": "button_click",
      "description": "手动触发规则验证",
      "request": {
        "action": "VALIDATE_RULES",
        "payload": {
          "task_id": "{{task_id}}"
        }
      },
      "response_handling": {
        "success": {
          "render_type": "update_section",
          "section": "validation",
          "data": "{{validation_results}}"
        },
        "error": {
          "render_type": "show_message",
          "message": "验证失败：{{error_message}}",
          "message_type": "error"
        }
      },
      "loading": {
        "show": true,
        "text": "正在验证规则..."
      }
    }
  ],
  "event_handlers": {
    "on_field_change": {
      "trigger": "field_value_changed",
      "handlers": [
        {
          "field_id_pattern": "transfer_.*",
          "action": "validate_transfer_delivery_distinction"
        },
        {
          "field_id_pattern": "delivery_.*",
          "action": "validate_transfer_delivery_distinction"
        }
      ]
    },
    "on_section_expand": {
      "trigger": "section_collapsed_changed",
      "handlers": [
        {
          "section_id": "product_coefficients",
          "action": "lazy_load_products"
        },
        {
          "section_id": "rebate_discount_rules",
          "action": "check_rebate_conflicts"
        }
      ]
    }
  }
}
