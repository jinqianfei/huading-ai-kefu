{
  "skill_id": "skill-contract-prefill",
  "version": "1.0.0",
  "description": "合同文件上传，自动提取计费规则，录入系统规则库",
  "input_fields": [
    {
      "field_id": "contract_file",
      "type": "file",
      "label": "上传合同文件",
      "accepted_formats": [".pdf", ".docx"],
      "max_size_mb": 50,
      "required": true,
      "description": "支持PDF和Word格式，优先可编辑版本"
    },
    {
      "field_id": "customer_id",
      "type": "select",
      "label": "选择客户",
      "options_source": "api:/customers",
      "searchable": true,
      "required": true
    },
    {
      "field_id": "contract_no",
      "type": "text",
      "label": "合同编号",
      "placeholder": "如：HT-RQ-2026-001",
      "required": false
    },
    {
      "field_id": "effective_date",
      "type": "date",
      "label": "合同生效日期",
      "required": false
    },
    {
      "field_id": "force_reparse",
      "type": "checkbox",
      "label": "强制重新解析（替换旧版本）",
      "default": false,
      "required": false
    }
  ]
}
