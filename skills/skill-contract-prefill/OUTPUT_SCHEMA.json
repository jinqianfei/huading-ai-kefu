{
  "skill_id": "skill-contract-prefill",
  "version": "2.3.0",
  "output_type": "contract_rules_review",
  "description": "合同规则审核输出结构，包含合同信息、计费模式、仓储规则、调拨报价、共配报价（含超规格/起运量）、标准件规则、产品系数、增值服务、特殊条款、返利折扣、验证结果",
  "fields": [
    {
      "section_id": "contract_info",
      "title": "合同基本信息",
      "confidence_threshold": 0.8,
      "fields": [
        { "field_id": "contract_no", "label": "合同编号", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "required": true },
        { "field_id": "customer_name", "label": "客户名称", "status_types": ["CONFIRMED"], "required": true },
        { "field_id": "effective_date", "label": "生效日期", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"] },
        { "field_id": "expiry_date", "label": "到期日期", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"] },
        { "field_id": "settlement_staff", "label": "结算专员", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"] }
      ]
    },
    {
      "section_id": "billing_mode",
      "title": "计费模式",
      "confidence_threshold": 0.95,
      "description": "⚠️ 必须先确定计费模式，再按对应模式提取规则",
      "fields": [
        { "field_id": "billing_mode", "label": "计费模式", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "required": true, "enum": ["pallet", "standard_unit", "hybrid"], "source_location": true },
        { "field_id": "billing_mode_desc", "label": "模式说明", "status_types": ["CONFIRMED"], "source_location": true },
        { "field_id": "billing_unit", "label": "计费单位", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "enum": ["托盘", "标准件", "混合"], "required": true }
      ]
    },
    {
      "section_id": "storage_rules",
      "title": "仓储费规则",
      "confidence_threshold": 0.85,
      "fields": [
        { "field_id": "period_days", "label": "计费周期天数", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "天", "applies_to": "standard_unit" },
        { "field_id": "storage_pricing", "label": "存储费（按仓库+温区）", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "source_location": true, "required": true },
        { "field_id": "operation_mode", "label": "操作费模式", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "enum": ["included", "separate", "none"], "required": true },
        { "field_id": "operation_fee_whole", "label": "操作费-整件（如单独收取）", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "元/标准件", "applies_to": "operation_mode:separate" },
        { "field_id": "operation_fee_split", "label": "操作费-拆零", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "元/最小单位" },
        { "field_id": "inbound_fee", "label": "入库费", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "元/托" },
        { "field_id": "overdue_enabled", "label": "是否收取超期费", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "enum": [true, false], "applies_to": "standard_unit" },
        { "field_id": "overdue_grace_days", "label": "超期宽限期", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "天", "applies_to": "overdue_enabled:true" },
        { "field_id": "overdue_fee_per_unit", "label": "超期费单价", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "元/件/天", "applies_to": "overdue_enabled:true" }
      ]
    },
    {
      "section_id": "transfer_rules",
      "title": "调拨报价（仓库间调拨）",
      "confidence_threshold": 0.85,
      "description": "⚠️ 调拨=仓库到仓库，与共配（仓库到门店）必须分开",
      "fields": [
        { "field_id": "transfer_min_order_qty", "label": "起运量", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "unit": "件" },
        { "field_id": "transfer_routes", "label": "调拨路线表", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true },
        { "field_id": "transfer_price_type", "label": "计费类型", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "enum": ["统一单价", "分路线计价"] },
        { "field_id": "transfer_unit", "label": "单位", "status_types": ["CONFIRMED"], "value": "元/标准件" }
      ]
    },
    {
      "section_id": "delivery_rules",
      "title": "共配报价（仓库到门店）",
      "confidence_threshold": 0.85,
      "description": "⚠️ 共配=仓库到门店，与调拨（仓库到仓库）必须分开",
      "fields": [
        { "field_id": "delivery_pricing_type", "label": "报价类型", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "enum": ["不分区间", "分区间", "数量区间", "专车", "冷链"], "required": true },
        { "field_id": "delivery_standard_unit_rule", "label": "标准件定义", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"] },
        
        { "field_id": "min_order_qty", "label": "起运量", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "unit": "件", "source_location": true, "required": true },
        { "field_id": "min_order_qty_by_warehouse", "label": "按仓库的起运量", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true, "description": "不同仓库可能有不同的起运量要求" },
        { "field_id": "min_order_qty_billing_mode", "label": "不足起运量计费方式", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "enum": ["按实际数量计费", "按起运量计费", "按起运量整数倍计费"], "source_location": true },
        
        { "field_id": "unit_price", "label": "单价", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "unit": "元/标准件", "required": true },
        { "field_id": "unit_price_by_warehouse", "label": "按仓库的单价", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true },
        { "field_id": "unit_price_by_zone", "label": "按区域的单价", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true },
        
        { "field_id": "min_fee", "label": "最低收费", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "元", "source_location": true },
        { "field_id": "min_fee_rule", "label": "最低收费规则", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true, "description": "如：不足起运量时按起运量×单价计费" },
        
        { "field_id": "routes", "label": "配送路线表", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true },
        { "field_id": "delivery_included_in_storage", "label": "配送费是否含在存储费", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "enum": [true, false] }
      ]
    },
    {
      "section_id": "oversized_rules",
      "title": "超规格计费规则",
      "confidence_threshold": 0.9,
      "description": "超出标准件定义（重量/体积）的计费规则",
      "fields": [
        { "field_id": "oversized_tiers", "label": "超标分级", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true, "required": true, "description": "如：一级超标（系数1.2）、二级超标（系数2.0）" },
        { "field_id": "oversized_tier1_threshold", "label": "一级超标阈值", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true, "description": "如：15kg<重量≤25kg 或 0.05m³<体积≤0.08m³" },
        { "field_id": "oversized_tier1_coef", "label": "一级超标系数", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "default": 1.2, "required": true },
        { "field_id": "oversized_tier2_threshold", "label": "二级超标阈值", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true },
        { "field_id": "oversized_tier2_coef", "label": "二级超标系数", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "default": 2.0 },
        { "field_id": "oversized_tier3_threshold", "label": "三级超标阈值", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true },
        { "field_id": "oversized_tier3_coef", "label": "三级超标系数", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"] },
        { "field_id": "extra_weight_fee", "label": "额外超重费用", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true, "description": "超出重量的额外费用，如：X元/件" },
        { "field_id": "oversized_billing_note", "label": "超规格计费特殊说明", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true }
      ]
    },
    {
      "section_id": "standard_unit_rules",
      "title": "标准件计算规则",
      "confidence_threshold": 0.9,
      "fields": [
        { "field_id": "max_weight_kg", "label": "最大重量", "status_types": ["CONFIRMED"], "unit": "kg", "default": 15 },
        { "field_id": "max_volume_m3", "label": "最大体积", "status_types": ["CONFIRMED"], "unit": "m³", "default": 0.05 },
        { "field_id": "calculation_rule", "label": "计算规则", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "description": "如：max(重量/最大重量, 体积/最大体积)" }
      ]
    },
    {
      "section_id": "product_coefficients",
      "title": "标准件系数",
      "confidence_threshold": 0.85,
      "description": "每个SKU的计费系数。固定SKU（合同商品参数表中）系数固定1.0；非固定SKU按超规格规则计算。",
      "fields": [
        { "field_id": "description", "label": "说明", "status_types": ["CONFIRMED"], "value": "产品标准件系数" },
        { "field_id": "coefficient_unit", "label": "系数单位", "status_types": ["CONFIRMED"], "value": "倍" },
        { "field_id": "standard_unit_definition", "label": "标准件定义", "status_types": ["CONFIRMED"], "description": "合同约定的标准件体积/重量阈值" },
        { "field_id": "max_weight_kg", "label": "最大重量(kg)", "status_types": ["CONFIRMED"], "default": 15 },
        { "field_id": "max_volume_m3", "label": "最大体积(m³)", "status_types": ["CONFIRMED"], "default": 0.05 },
        { "field_id": "fixed_skus", "label": "固定SKU列表", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true, "description": "格式：{SKU编码: {name, spec, volume_m3, weight_kg}}" },
        { "field_id": "fixed_sku_count", "label": "固定SKU数量", "status_types": ["CONFIRMED", "NOT_FOUND"] },        { "field_id": "oversized_rules", "label": "超规格规则", "status_types": ["CONFIRMED", "LOW_CONFIDENCE"], "description": "非固定SKU的超规格计费系数规则" }
      ]
    },
    {
      "section_id": "value_added_rules",
      "title": "增值服务费",
      "confidence_threshold": 0.8,
      "fields": [
        { "field_id": "sorting_fee", "label": "混装分拣费", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "元/件" },
        { "field_id": "repackaging_fee", "label": "再包装费", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "元/件" },
        { "field_id": "labeling_fee", "label": "贴标费", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "元/件" },
        { "field_id": "delivery_to_store_fee", "label": "送货进店费", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "元/件" },
        { "field_id": "market_distribution_fee", "label": "代发市场费用", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true, "description": "如：20件起，2元/件" }
      ]
    },
    {
      "section_id": "special_rules",
      "title": "特殊条款",
      "confidence_threshold": 0.8,
      "fields": [
        { "field_id": "difficult_delivery_surcharge", "label": "困难配送加收", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "%" },
        { "field_id": "delivery_period", "label": "配送周期", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true, "description": "如：一周六配、一周三配等" },
        { "field_id": "delivery_time_limit", "label": "配送时效", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true, "description": "如：1-2天" },
        { "field_id": "other_special", "label": "其他特殊条款", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true }
      ]
    },
    {
      "section_id": "rebate_discount_rules",
      "title": "返利/折扣条款",
      "confidence_threshold": 0.75,
      "description": "⚠️ 返利折扣需人工确认后生效",
      "fields": [
        { "field_id": "rebate_type", "label": "返利类型", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "enum": ["月发货量阶梯", "固定折扣", "无"] },
        { "field_id": "rebate_conditions", "label": "返利条件", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "source_location": true },
        { "field_id": "rebate_ratio", "label": "返利比例", "status_types": ["CONFIRMED", "LOW_CONFIDENCE", "NOT_FOUND"], "unit": "%" }
      ]
    },
    {
      "section_id": "validation",
      "title": "验证结果",
      "confidence_threshold": 0.9,
      "fields": [
        { "field_id": "transfer_delivery_distinction", "label": "调拨/共配是否区分", "status_types": ["CONFIRMED", "NOT_DISTINGUISHED"] },
        { "field_id": "pricing_complete", "label": "报价是否完整", "status_types": ["CONFIRMED", "INCOMPLETE"] },
        { "field_id": "min_order_qty_identified", "label": "起运量是否明确", "status_types": ["CONFIRMED", "NOT_IDENTIFIED"] },
        { "field_id": "oversized_rules_identified", "label": "超规格规则是否明确", "status_types": ["CONFIRMED", "NOT_IDENTIFIED"] },
        { "field_id": "min_fee_valid", "label": "最低收费是否验证", "status_types": ["CONFIRMED", "NOT_VERIFIED"] },
        { "field_id": "cross_validation_passed", "label": "交叉验证是否通过", "status_types": ["PASSED", "FAILED"] },
        { "field_id": "confusion_marks", "label": "疑点标记列表", "status_types": ["NONE", "HAS_MARKS"] }
      ]
    },
    {
      "section_id": "summary",
      "title": "摘要",
      "confidence_threshold": 0.85,
      "fields": [
        { "field_id": "total_confirmed_fields", "label": "已确认字段数", "status_types": ["CONFIRMED"] },
        { "field_id": "total_low_confidence_fields", "label": "低置信度字段数", "status_types": ["LOW_CONFIDENCE"] },
        { "field_id": "total_not_found_fields", "label": "未找到字段数", "status_types": ["NOT_FOUND"] },
        { "field_id": "extraction_notes", "label": "提取说明", "status_types": ["CONFIRMED"] },
        { "field_id": "next_steps", "label": "下一步", "status_types": ["CONFIRMED"] }
      ]
    }
  ]
}
