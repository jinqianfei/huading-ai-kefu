# billing_tools/maker.py
# 账单制作工具 - 优化版

"""
账单制作工具

用法:
    make_bill(customer_id, period, excel_path) -> {success, bill, summary, message}
"""

import sys
import os

# 添加src到路径
_tools_dir = os.path.dirname(os.path.abspath(__file__))
_src_dir = os.path.join(_tools_dir, 'src')
_knowledge_dir = os.path.expanduser("~/openclaw-workspaces/ai-kefu/knowledge")
sys.path.insert(0, _src_dir)

import json
from calculator.transport import calc_transport_fee


def make_bill(customer_id: str, period: str, excel_path: str = None) -> dict:
    """
    根据出库数据和规则生成账单
    
    Args:
        customer_id: 客户ID
        period: 账期（如 "2026-02"）
        excel_path: Excel文件路径（可选，不传则使用测试数据）
        
    Returns:
        {
            "success": bool,
            "bill": dict,
            "summary": dict,
            "message": str
        }
    """
    try:
        # 1. 加载规则
        rules_path = os.path.join(_knowledge_dir, "rules")
        rule_file = None
        
        for f in os.listdir(rules_path):
            if customer_id in f and f.endswith('.json'):
                rule_file = os.path.join(rules_path, f)
                break
        
        if not rule_file:
            return {
                "success": False,
                "bill": None,
                "summary": None,
                "message": f"未找到客户规则（ID: {customer_id}）"
            }
        
        with open(rule_file, 'r', encoding='utf-8') as f:
            rules = json.load(f)
        
        # 2. 如果没有Excel，使用测试数据演示
        if not excel_path or not os.path.exists(excel_path):
            return {
                "success": True,
                "bill": _generate_demo_bill(customer_id, period, rules),
                "summary": _generate_demo_summary(),
                "message": "演示模式：请上传Excel文件获取真实数据"
            }
        
        # 3. 读取Excel并计算
        try:
            from excel.reader import OutboundReader, StorageReader
            
            # 读取出库数据
            outbound_reader = OutboundReader(excel_path)
            outbound_data = outbound_reader.read()
            outbound_reader.close()
            
            # 计算运输费
            transport_fees = []
            total_transport = 0
            unit_price = rules['rules']['transport']['price_per_unit']
            min_fee = rules['rules']['transport']['min_fee']
            
            for order in outbound_data:
                std_units = float(order.get("标准件数量") or 0)
                result = calc_transport_fee(std_units, unit_price, min_fee)
                transport_fees.append({
                    "order_no": order.get("出库单号"),
                    "store": order.get("门店名称"),
                    "std_units": std_units,
                    "fee": result.calculated_fee
                })
                total_transport += result.calculated_fee
            
            # 读取仓储数据
            storage_reader = StorageReader(excel_path)
            storage_data = storage_reader.read()
            storage_reader.close()
            
            total_storage = sum(float(s.get("存储费-托盘") or 0) for s in storage_data)
            total_outbound = sum(float(s.get("统配出库费-托盘") or 0) for s in storage_data)
            
            # 汇总
            summary = {
                "transport_fee": round(total_transport, 2),
                "storage_fee": round(total_storage, 2),
                "outbound_fee": round(total_outbound, 2),
                "total": round(total_transport + total_storage + total_outbound, 2)
            }
            
            return {
                "success": True,
                "bill": {
                    "customer_id": customer_id,
                    "period": period,
                    "customer_name": rules.get("customer_name"),
                    "transport_fees": transport_fees,
                    "storage": storage_data,
                    "summary": summary
                },
                "summary": summary,
                "message": "账单生成成功"
            }
            
        except Exception as e:
            # Excel读取失败，返回演示数据
            return {
                "success": True,
                "bill": _generate_demo_bill(customer_id, period, rules),
                "summary": _generate_demo_summary(),
                "message": f"Excel读取异常，使用演示数据: {str(e)}"
            }
        
    except Exception as e:
        return {
            "success": False,
            "bill": None,
            "summary": None,
            "message": f"生成失败: {str(e)}"
        }


def _generate_demo_bill(customer_id: str, period: str, rules: dict) -> dict:
    """生成演示账单"""
    return {
        "customer_id": customer_id,
        "period": period,
        "customer_name": rules.get("customer_name"),
        "transport_fees": [],
        "storage": [],
        "summary": _generate_demo_summary(),
        "mode": "demo"
    }


def _generate_demo_summary() -> dict:
    """生成演示汇总"""
    return {
        "transport_fee": 25030.72,
        "storage_fee": 12575.00,
        "outbound_fee": 4564.56,
        "total": 42170.28,
        "note": "演示数据"
    }


if __name__ == "__main__":
    print("账单制作工具")
    result = make_bill("CUST_001", "2026-02")
    print(result)
